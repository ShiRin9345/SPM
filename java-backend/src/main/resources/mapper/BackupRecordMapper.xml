<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team.lms.mapper.BackupRecordMapper">

    <resultMap id="BackupRecordResultMap" type="com.team.lms.entity.BackupRecord">
        <id property="id" column="id"/>
        <result property="backupName" column="backup_name"/>
        <result property="filePath" column="file_path"/>
        <result property="status" column="status"/>
        <result property="summary" column="summary"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectAll" resultMap="BackupRecordResultMap">
        select * from backup_records
        where deleted = false
        order by created_at desc, id desc
    </select>

    <select id="selectLatest" resultMap="BackupRecordResultMap">
        select * from backup_records
        where deleted = false
        order by created_at desc, id desc
        limit 1
    </select>

    <insert id="insert" parameterType="com.team.lms.entity.BackupRecord" useGeneratedKeys="true" keyProperty="id">
        insert into backup_records(backup_name, file_path, status, summary, created_at, updated_at, deleted)
        values(#{backupName}, #{filePath}, #{status}, #{summary}, now(), now(), false)
    </insert>
</mapper>
