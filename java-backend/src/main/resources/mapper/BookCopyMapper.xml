<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team.lms.mapper.BookCopyMapper">

    <resultMap id="BookCopyResultMap" type="com.team.lms.entity.BookCopy">
        <id property="id" column="id"/>
        <result property="copyNo" column="copy_no"/>
        <result property="barcode" column="barcode"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
        <association property="book" javaType="com.team.lms.entity.Book">
            <id property="id" column="book_id"/>
        </association>
    </resultMap>

    <select id="selectByBookId" resultMap="BookCopyResultMap">
        select * from book_copies
        where book_id = #{bookId}
        order by copy_no asc, id asc
    </select>

    <select id="selectActiveByBookId" resultMap="BookCopyResultMap">
        select * from book_copies
        where book_id = #{bookId} and deleted = false
        order by copy_no asc, id asc
    </select>

    <select id="selectByBarcode" resultMap="BookCopyResultMap">
        select * from book_copies
        where barcode = #{barcode} and deleted = false
        limit 1
    </select>

    <select id="selectMaxCopyNoByBookId" resultType="int">
        select max(copy_no)
        from book_copies
        where book_id = #{bookId} and deleted = false
    </select>

    <insert id="insert" parameterType="com.team.lms.entity.BookCopy" useGeneratedKeys="true" keyProperty="id">
        insert into book_copies(book_id, copy_no, barcode, created_at, updated_at, deleted)
        values(#{book.id}, #{copyNo}, #{barcode}, now(), now(), false)
    </insert>

    <delete id="softDeleteByIds">
        delete from book_copies
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="softDeleteByBookId">
        delete from book_copies
        where book_id = #{bookId}
    </delete>
</mapper>
